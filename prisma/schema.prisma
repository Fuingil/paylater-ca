generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactInquiry {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String?
  phone       String?
  offerAmount String?
  message     String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}
