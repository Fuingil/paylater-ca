generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactInquiry {
  id          String           @id @default(cuid())
  name        String
  email       String
  company     String?
  phone       String?
  offerAmount String?
  message     String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime         @default(now())
  messages    InquiryMessage[]
}

model InquiryMessage {
  id        String         @id @default(cuid())
  inquiryId String
  inquiry   ContactInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  direction String
  body      String         @db.Text
  subject   String?
  fromEmail String
  toEmail   String
  resendId  String?        @unique
  createdAt DateTime       @default(now())

  @@index([inquiryId, createdAt])
}
